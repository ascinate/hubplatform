'use client'

import { useState, useMemo } from 'react'
import Link from 'next/link'
import {
  ClipboardCheck,
  BarChart3,
  TrendingUp,
  ArrowRight,
  Play,
  X,
  Loader2,
  CheckCircle,
  Shield,
  Zap,
  Globe,
  Users,
  ChevronRight,
} from 'lucide-react'
import { toast } from 'sonner'
import axios from 'axios'

export default function MarketingHomePage() {
  const [showDemo, setShowDemo] = useState(false)
  const [demoForm, setDemoForm] = useState({
    full_name: '',
    email: '',
    company_name: '',
    phone: '',
  })
  const [submittingDemo, setSubmittingDemo] = useState(false)

  // Newsletter
  const [newsletterEmail, setNewsletterEmail] = useState('')

  // ROI Calculator
  const [teamMembers, setTeamMembers] = useState(10)
  const [avgSalary, setAvgSalary] = useState(3500)

  const roi = useMemo(() => {
    const annualOverhead = teamMembers * avgSalary * 12
    const savings = annualOverhead * 0.35
    const investment = 2999 * 12
    const netSavings = savings - investment
    const paybackMonths = savings > 0 ? investment / (savings / 12) : 0
    return { annualOverhead, savings, investment, netSavings, paybackMonths }
  }, [teamMembers, avgSalary])

  const handleDemoSubmit = async (e: React.FormEvent) => {
    e.preventDefault()
    if (!demoForm.full_name || !demoForm.email) {
      toast.error('Please fill in your name and email')
      return
    }

    setSubmittingDemo(true)
    try {
      await axios.post('https://app.sankalphub.in/api/demo-request/', demoForm)
      toast.success('Demo request submitted! We\'ll be in touch shortly.')
      setShowDemo(false)
      setDemoForm({ full_name: '', email: '', company_name: '', phone: '' })
    } catch {
      toast.error('Failed to submit demo request. Please try again.')
    } finally {
      setSubmittingDemo(false)
    }
  }

  const handleNewsletterSubmit = (e: React.FormEvent) => {
    e.preventDefault()
    if (!newsletterEmail) {
      toast.error('Please enter your email')
      return
    }
    toast.success('Thanks for subscribing!')
    setNewsletterEmail('')
  }

  const scrollTo = (id: string) => {
    const el = document.getElementById(id)
    if (el) el.scrollIntoView({ behavior: 'smooth' })
  }

  return (
    <div className="min-h-screen bg-white">
      {/* Glass Nav Bar */}
      <nav className="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-border/50">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="flex items-center justify-between h-16">
            <Link href="/home" className="flex items-center gap-2">
              <div className="w-9 h-9 bg-primary rounded-lg flex items-center justify-center">
                <span className="text-white font-bold text-lg">S</span>
              </div>
              <span className="text-xl font-bold text-text-primary">SankalpHub</span>
            </Link>

            <div className="hidden md:flex items-center gap-8">
              <button
                onClick={() => scrollTo('features')}
                className="text-sm text-text-muted hover:text-text-primary transition-colors"
              >
                Features
              </button>
              <button
                onClick={() => scrollTo('solutions')}
                className="text-sm text-text-muted hover:text-text-primary transition-colors"
              >
                Solutions
              </button>
              <button
                onClick={() => scrollTo('calculator')}
                className="text-sm text-text-muted hover:text-text-primary transition-colors"
              >
                Savings
              </button>
              <Link href="/pricing" className="text-sm text-text-muted hover:text-text-primary transition-colors">
                Pricing
              </Link>
            </div>

            <div className="flex items-center gap-3">
              <Link
                href="/login"
                className="text-sm font-medium text-text-primary hover:text-primary transition-colors"
              >
                Login
              </Link>
              <button
                onClick={() => setShowDemo(true)}
                className="px-4 py-2 bg-primary hover:bg-primary-hover text-white text-sm font-semibold rounded-lg transition-colors"
              >
                Get Demo
              </button>
            </div>
          </div>
        </div>
      </nav>

      {/* Hero Section */}
      <section className="pt-32 pb-20 px-4">
        <div className="max-w-6xl mx-auto text-center">
          <span className="inline-block px-4 py-1.5 bg-primary-light text-primary text-sm font-medium rounded-full mb-6">
            Production &amp; Inspection Intelligence Platform
          </span>

          <h1 className="text-4xl sm:text-5xl md:text-6xl font-bold text-text-primary mb-6 leading-tight">
            SANKALP &mdash; Driven by Determination.
            <br />
            <span className="text-primary">Powered by Discipline.</span>
          </h1>

          <p className="text-lg md:text-xl text-text-muted max-w-2xl mx-auto mb-10">
            Unifying Sampling, Production, Inspection, and Testing into one disciplined workflow system
          </p>

          <div className="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
            <button
              onClick={() => setShowDemo(true)}
              className="px-8 py-3.5 bg-primary hover:bg-primary-hover text-white font-semibold rounded-lg transition-colors flex items-center gap-2"
            >
              Request Demo
              <ArrowRight size={18} />
            </button>
            <button className="px-8 py-3.5 border-2 border-border text-text-primary font-semibold rounded-lg hover:border-primary hover:text-primary transition-colors flex items-center gap-2">
              <Play size={18} />
              Watch Video
            </button>
          </div>

          {/* Stats Strip */}
          <div className="flex flex-col sm:flex-row items-center justify-center gap-8 sm:gap-16">
            <div className="flex items-center gap-3">
              <div className="w-12 h-12 bg-success-light rounded-xl flex items-center justify-center">
                <TrendingUp size={22} className="text-success" />
              </div>
              <div className="text-left">
                <p className="text-2xl font-bold text-text-primary">+34%</p>
                <p className="text-sm text-text-muted">Faster Error Reduction</p>
              </div>
            </div>
            <div className="flex items-center gap-3">
              <div className="w-12 h-12 bg-primary-light rounded-xl flex items-center justify-center">
                <Zap size={22} className="text-primary" />
              </div>
              <div className="text-left">
                <p className="text-2xl font-bold text-text-primary">1.2 Month</p>
                <p className="text-sm text-text-muted">Payback Period</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* Trusted By Section */}
      <section className="py-12 border-y border-border/50 bg-gray-50/50">
        <div className="max-w-5xl mx-auto px-4">
          <p className="text-center text-sm text-text-muted uppercase tracking-wider mb-8">
            Trusted by industry leaders
          </p>
          <div className="flex flex-wrap items-center justify-center gap-8 sm:gap-14">
            {['GLOBALWEAR', 'LOGISTX', 'PRIME+', 'SMARTCHAIN', 'TECHFABRIC'].map((name) => (
              <span
                key={name}
                className="text-lg font-bold text-text-muted/50 tracking-widest select-none"
              >
                {name}
              </span>
            ))}
          </div>
        </div>
      </section>

      {/* Features Grid */}
      <section id="features" className="py-20 px-4">
        <div className="max-w-6xl mx-auto">
          <div className="text-center mb-14">
            <span className="inline-block px-3 py-1 bg-primary-light text-primary text-xs font-semibold rounded-full uppercase tracking-wider mb-4">
              Capabilities
            </span>
            <h2 className="text-3xl md:text-4xl font-bold text-text-primary mb-4">
              Everything You Need, In One Platform
            </h2>
            <p className="text-text-muted max-w-xl mx-auto">
              From digital inspections to analytics, SankalpHub covers every aspect of your production workflow.
            </p>
          </div>

          <div className="grid grid-cols-1 md:grid-cols-3 gap-8">
            {/* Card 1 — Digital Inspection */}
            <div className="bg-white border border-border rounded-2xl p-8 hover:shadow-elevated transition-shadow group">
              <div className="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary transition-colors">
                <ClipboardCheck size={26} className="text-primary group-hover:text-white transition-colors" />
              </div>
              <h3 className="text-xl font-bold text-text-primary mb-3">Digital Inspection</h3>
              <p className="text-text-muted text-sm leading-relaxed mb-4">
                Digitize your entire inspection process with real-time data capture and automated PDF report generation.
              </p>
              <ul className="space-y-2">
                {['PDF Report generation', 'Offline data capture', 'Real-time alerts'].map((item) => (
                  <li key={item} className="flex items-center gap-2 text-sm text-text-muted">
                    <CheckCircle size={16} className="text-success flex-shrink-0" />
                    {item}
                  </li>
                ))}
              </ul>
            </div>

            {/* Card 2 — Production Tracking */}
            <div className="bg-white border border-border rounded-2xl p-8 hover:shadow-elevated transition-shadow group">
