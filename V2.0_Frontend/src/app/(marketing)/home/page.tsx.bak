                <BarChart3 size={26} className="text-primary group-hover:text-white transition-colors" />
              </div>
              <h3 className="text-xl font-bold text-text-primary mb-3">Production Tracking</h3>
              <p className="text-text-muted text-sm leading-relaxed mb-4">
                Track production milestones, critical path alerts, and vendor performance from a unified hub.
              </p>
              <ul className="space-y-2">
                {['Critical Path Alerts', 'Unified Vendor Hub', 'Order tracking'].map((item) => (
                  <li key={item} className="flex items-center gap-2 text-sm text-text-muted">
                    <CheckCircle size={16} className="text-success flex-shrink-0" />
                    {item}
                  </li>
                ))}
              </ul>
            </div>

            {/* Card 3 — Analytics Engine */}
            <div className="bg-white border border-border rounded-2xl p-8 hover:shadow-elevated transition-shadow group">
              <div className="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary transition-colors">
                <TrendingUp size={26} className="text-primary group-hover:text-white transition-colors" />
              </div>
              <h3 className="text-xl font-bold text-text-primary mb-3">Analytics Engine</h3>
              <p className="text-text-muted text-sm leading-relaxed mb-4">
                Automated KPI dashboards and benchmarking reports to power data-driven decisions.
              </p>
              <ul className="space-y-2">
                {['Automated KPI Dashboards', 'Benchmarking Reports', 'Trend analysis'].map((item) => (
                  <li key={item} className="flex items-center gap-2 text-sm text-text-muted">
